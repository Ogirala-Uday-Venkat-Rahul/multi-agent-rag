# ---- LLM provider ----
# One of: groq | gemini | openai | anthropic
# groq and gemini have free tiers and are the recommended default for free hosting.
LLM_PROVIDER=groq

# Leave LLM_MODEL blank to use the sensible default for the chosen provider
# (groq: llama-3.3-70b-versatile, gemini: gemini-2.0-flash,
#  openai: gpt-4o-mini, anthropic: claude-opus-4-8).
LLM_MODEL=

# Only the key for your chosen provider is needed.
GROQ_API_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---- Vector store ----
# chroma  -> zero-setup local file store (default)
# pgvector -> Postgres + pgvector (set DATABASE_URL); use Supabase/Neon free tier in prod
VECTOR_STORE=chroma
CHROMA_PATH=./.chroma
DATABASE_URL=

# ---- Models that run locally (CPU, free) ----
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ---- Retrieval / pipeline knobs ----
COLLECTION_NAME=documents
CHUNK_SIZE=800
CHUNK_OVERLAP=120
TOP_K_VECTOR=10
TOP_K_BM25=10
TOP_K_RERANK=4
MAX_SUBQUESTIONS=4
MAX_ITERATIONS=2
FAITHFULNESS_THRESHOLD=0.7
